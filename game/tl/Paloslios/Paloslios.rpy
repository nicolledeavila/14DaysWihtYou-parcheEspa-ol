    mcall "*ejem*… {size=+5}¡Atención a todos! [they!c][are] ¡con muchas ganas!{/size}" with vpunch

# game/scripts/days/day 1.rpy:1672
translate Paloslios mothaltintro_248ef461:

    # mcall "{size=+10}And for a guy who doesn't even know how to grow a backbone!{/size}" with vpunch
    mcall "{size=+10}¡Y para un chico que ni siquiera sabe cómo hacer crecer su columna vertebral!{/size}" with vpunch

# game/scripts/days/day 1.rpy:1673
translate Paloslios mothaltintro_e63f0d3e:

    # y "Ugh, I'm not saying {i}anything!{/i} But your neighbours will if you keep shouting like that!"
