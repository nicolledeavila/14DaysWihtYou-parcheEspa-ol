# game/scripts/days/day 1.rpy:1675
translate Paloslios mothaltintro_cfce7f3d:

    # mcall "Yeah, yeah. Okay. Look! If it were me, I'd text him back as soon as possible. Maybe even give him a call instead if his voice was as {i}\"submissive and breedable\"{/i} as you said it was."
    mcall "Sí, sí. Bueno. ¡Mirar! Si fuera yo, le respondería lo antes posible. Tal vez incluso llamarlo si su voz era tan {i}\"sumisa y educable\"{/i} como dijiste que era."

# game/scripts/days/day 1.rpy:1676
translate Paloslios mothaltintro_8def375a:

    # y "I literally never said that?!"
    y "¡¿Literalmente nunca dije eso ?!"

# game/scripts/days/day 1.rpy:1678
translate Paloslios mothaltintro_85a28269:

    # mcall "If that's what you wanna believe!"
    mcall "¡Si eso es lo que quieres creer!"

# game/scripts/days/day 1.rpy:1679
translate Paloslios mothaltintro_15c9d1fd:

    # n "[dammit!c], their laughter was contagious."
    n "[dammit!c], su risa era contagiosa."

# game/scripts/days/day 1.rpy:1681
translate Paloslios mothaltintro_3749a190:

    # mcall "Why are you still talking to me anyway? Go call up your precious little Haruko 2.0. I got some webcomics I need to catch up on anyway."
    mcall "¿Por qué sigues hablando conmigo de todos modos? Ve a llamar a tu pequeño y precioso Haruko 2.0. De todos modos tengo algunos webcomics que necesito ponerme al día."

# game/scripts/days/day 1.rpy:1682
translate Paloslios mothaltintro_e517b335:

